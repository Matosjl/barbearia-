# ============================================================================
#  BARBER SAAS — variáveis de ambiente (copie para .env e ajuste)
#  REGRA: nenhum serviço usa localhost/IP fixo. Hosts = NOMES DE CONTAINER.
#  Para split multi-VPS, basta trocar o host (ex.: OLLAMA_HOST=ollama.vps2.mesh).
# ============================================================================

# ---- Geral ----
NODE_ENV=production
TZ=America/Sao_Paulo
PUBLIC_DOMAIN=app.suabarbearia.com.br

# ---- PostgreSQL (host = nome do container) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=barber
POSTGRES_USER=barber_app
POSTGRES_PASSWORD=troque-esta-senha
# usuário owner/admin para migrações (bypass RLS)
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=troque-esta-senha-admin
DATABASE_URL=postgres://barber_app:troque-esta-senha@postgres:5432/barber

# ---- Redis (cache + filas BullMQ + adapter do Socket.io) ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ---- Backend / Auth ----
BACKEND_HOST=backend
BACKEND_PORT=3000
JWT_ACCESS_SECRET=troque-access-secret
JWT_REFRESH_SECRET=troque-refresh-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ---- Evolution API (WhatsApp) ----
EVOLUTION_HOST=evolution
EVOLUTION_PORT=8080
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=troque-evolution-key
# Evolution usa seu próprio database no mesmo Postgres
EVOLUTION_DB=evolution

# ---- Ollama (IA local) ----
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1

# ---- Uploads (local no início; depois Cloudinary/S3) ----
UPLOAD_DRIVER=local
UPLOAD_DIR=/data/uploads
# CLOUDINARY_URL=

# ---- Backup ----
BACKUP_CRON=0 3 * * *
BACKUP_RETENTION_DAYS=14
# Opcional: enviar dump para object storage
# S3_BUCKET= S3_ENDPOINT= S3_ACCESS_KEY= S3_SECRET_KEY=
